{
  "name": "easyfunding",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "mobile:init": "node scripts/mobile-init.mjs",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "dev:mobile": "vite --host 0.0.0.0 --port 5173",
    "cap:use:dev": "copy /Y capacitor.config.dev.ts capacitor.config.ts",
    "cap:use:prod": "copy /Y capacitor.config.prod.ts capacitor.config.ts",
    "cap:add:android": "cap add android",
    "cap:sync": "npm run cap:use:prod && cap sync",
    "cap:sync:dev": "npm run cap:use:dev && cap sync",
    "cap:run:android": "npm run cap:use:prod && cap run android",
    "cap:run:android:dev": "npm run cap:use:dev && cap run android",
    "mobile:dev": "npm run dev:mobile"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/local-notifications": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.1",
    "@tanstack/vue-table": "^8.21.3",
    "axios": "^1.13.2",
    "lucide-vue-next": "^0.562.0",
    "maska": "^3.2.0",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3",
    "vue3-toastify": "^0.2.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.23",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.0",
    "vite": "^7.2.4",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vue-tsc": "^3.1.5"
  }
}
